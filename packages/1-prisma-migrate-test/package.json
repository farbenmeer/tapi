{
  "name": "@farbenmeer/prisma-migrate-test",
  "version": "0.1.0",
  "author": {
    "name": "Michel Smola",
    "email": "michel.smola@farbenmeer.de"
  },
  "type": "module",
  "private": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "default": "./dist/sqlite.js"
    },
    "./pglite": {
      "types": "./dist/pglite.d.ts",
      "default": "./dist/pglite.js"
    }
  },
  "scripts": {
    "build": "tsc --noEmit false",
    "release": "pnpm build && pnpm publish",
    "generate:e2e": "prisma generate --schema=./e2e/prisma/pglite/schema.prisma && prisma generate --schema=./e2e/prisma/sqlite/schema.prisma",
    "test": "pnpm generate:e2e && vitest",
    "test:unit": "vitest run src",
    "test:e2e": "vitest run e2e"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": ">=6.0.0",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.0.3",
    "better-sqlite3": "^12.6.2",
    "pglite-prisma-adapter": "^0.7.0",
    "prisma": ">=6.0.0",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "better-sqlite3": "^12.0.0",
    "pglite-prisma-adapter": "^0.7.0"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": { "optional": true },
    "@prisma/adapter-better-sqlite3": { "optional": true },
    "better-sqlite3": { "optional": true },
    "pglite-prisma-adapter": { "optional": true }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farbenmeer/tapi.git"
  }
}
