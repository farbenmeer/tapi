{
  "name": "@farbenmeer/tag-based-cache",
  "version": "0.4.0",
  "author": {
    "name": "Michel Smola",
    "email": "michel.smola@farbenmeer.de"
  },
  "type": "module",
  "private": false,
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts",
    "filesystem-cache.js",
    "filesystem-cache.d.ts",
    "redis-cache.js",
    "redis-cache.d.ts",
    "postgres-cache.js",
    "postgres-cache.d.ts",
    "in-memory-cache.js",
    "in-memory-cache.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./filesystem-cache": {
      "types": "./filesystem-cache.d.ts",
      "default": "./filesystem-cache.js"
    },
    "./redis-cache": {
      "types": "./redis-cache.d.ts",
      "default": "./redis-cache.js"
    },
    "./postgres-cache": {
      "types": "./postgres-cache.d.ts",
      "default": "./postgres-cache.js"
    },
    "./in-memory-cache": {
      "types": "./in-memory-cache.d.ts",
      "default": "./in-memory-cache.js"
    }
  },
  "scripts": {
    "release": "pnpm publish --no-git-checks"
  },
  "dependencies": {
    "@toapi/cache": "workspace:^"
  },
  "peerDependencies": {
    "@redis/client": "^5.10.0 || ^6.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@redis/client": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farbenmeer/tapi.git"
  }
}
