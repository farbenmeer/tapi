{
  "name": "@farbenmeer/tapi-app-template",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "Template scaffolded by create-tapi-app — TApi on top of Nitro + Vite + React.",
  "files": [
    "src",
    "index.html",
    "nitro.config.ts",
    "vite.config.ts",
    "vite.sw.config.ts",
    "tsconfig.json",
    "Dockerfile",
    ".gitignore",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.sw.config.ts && vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@farbenmeer/lacy": "workspace:^",
    "@farbenmeer/react-tapi": "workspace:^",
    "@farbenmeer/router": "workspace:^",
    "@farbenmeer/tapi": "workspace:^",
    "h3": "2.0.1-rc.20",
    "nitro": "3.0.260415-beta",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^6.0.0"
  }
}
